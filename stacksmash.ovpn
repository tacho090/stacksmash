client
dev tun
proto tcp
remote gateway.stacksmash.io 1194
resolv-retry infinite
nobind
remote-cert-tls server
cipher AES-256-GCM
data-ciphers AES-256-GCM:CHACHA20-POLY1305
auth SHA256
verb 3
auth-user-pass
script-security 2
up /etc/openvpn/update-systemd-resolved
down /etc/openvpn/update-systemd-resolved
down-pre

